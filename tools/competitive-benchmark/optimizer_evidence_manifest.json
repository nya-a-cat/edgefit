{
  "schema": "edgefit.competitive_benchmark_manifest.v1",
  "corpus_manifest": "../onnx-normalize/real_world_corpus.json",
  "corpus_cache": "../../tmp/real_world_corpus",
  "default_target": "../../targets/virtual-npu.yaml",
  "cases": [
    {
      "id": "optimizer-linear-1000",
      "purpose": "Simulated 1K-node optimizer scale and deterministic plan evidence",
      "tags": ["optimizer", "performance", "synthetic", "linear-chain", "1k", "simulated"],
      "edgefit_command": "optimize",
      "generated_model": {
        "kind": "linear_op_chain",
        "node_count": 1000,
        "tensor_elements": 1024,
        "dtype": "int8",
        "op_type": "Relu"
      },
      "expectations": {
        "max_edgefit_duration_ms": 30000,
        "max_edgefit_peak_rss_bytes": 1073741824,
        "require_deterministic_artifact": true,
        "expected_plan_status": "pass",
        "expected_plan_assignment_count": 1000,
        "expected_plan_assignment_counts": {"npu": 1000},
        "expected_plan_segment_count": 1,
        "max_plan_spill_bytes": 0,
        "min_plan_event_kind_counts": {"load": 1, "store": 1},
        "max_plan_peak_scratchpad_bytes": 262144,
        "expected_plan_blockers": [],
        "expected_plan_recipe_ids": [],
        "require_plan_latency_improvement": true
      }
    },
